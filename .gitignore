#.vscode/

# Flutter/Dart/Pub related
**/doc/api/
**/ios/Flutter/.last_build_id
.dart_tool/
.flutter-plugins-dependencies
.pub-cache/
.pub/
/build/
/coverage/

# Symbolication related
app.*.symbols

# Obfuscation related
app.*.map.json

# Android Studio will place build artifacts here
/android/app/debug
/android/app/profile
/android/app/release

# Gradle cache
/android/.gradle/
/android/.kotlin/
/android/build/

# Local config
/android/local.properties

# App backups
/.backup/

# Platform ephemeral symlinks
/windows/flutter/ephemeral/
/linux/flutter/ephemeral/
/ios/Runner/GeneratedPluginRegistrant.*
/macos/Flutter/GeneratedPluginRegistrant.*

# iOS build artifacts
/ios/Flutter/ephemeral/
/ios/Flutter/flutter_export_environment.sh

# Other platforms (only android needed)
/ios/
/macos/
/linux/
/web/
/windows/
/test/

# Temp files
/sed*
/tmp/
*.salive

# APK / ZIP artifacts (built by CI)
*.apk
*.zip
*.part.*
