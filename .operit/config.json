{
    "projectType": "flutter",
    "title": "Flutter 项目",
    "description": "Flutter 跨平台应用模板，包含 Android、iOS、Web 和桌面端基础结构",
    "server": {
        "enabled": false,
        "port": 5013,
        "autoStart": false
    },
    "preview": {
        "type": "terminal",
        "url": "http://localhost:5013",
        "showPreviewButton": true,
        "previewButtonLabel": "浏览器预览"
    },
    "commands": [
        {
            "id": "flutter_android_setup_env",
            "label": "初始化环境",
            "command": "bash android/setup_android_env.sh",
            "workingDir": ".",
            "shell": true
        },
        {
            "id": "flutter_doctor",
            "label": "检查 Flutter 环境",
            "command": "flutter doctor",
            "workingDir": ".",
            "shell": true
        },
        {
            "id": "flutter_pub_get",
            "label": "获取依赖",
            "command": "flutter pub get",
            "workingDir": ".",
            "shell": true
        },
        {
            "id": "flutter_run_web_server",
            "label": "启动 Web 预览",
            "command": "flutter run -d web-server --web-hostname 0.0.0.0 --web-port 5013",
            "workingDir": ".",
            "shell": true,
            "usesDedicatedSession": true,
            "sessionTitle": "Flutter Web Server"
        },
        {
            "id": "flutter_analyze",
            "label": "静态检查",
            "command": "flutter analyze",
            "workingDir": ".",
            "shell": true
        },
        {
            "id": "flutter_test",
            "label": "运行测试",
            "command": "flutter test",
            "workingDir": ".",
            "shell": true
        },
        {
            "id": "flutter_build_apk",
            "label": "构建 APK",
            "command": "flutter build apk",
            "workingDir": ".",
            "shell": true
        },
        {
            "id": "flutter_build_web",
            "label": "构建 Web",
            "command": "flutter build web --no-tree-shake-icons",
            "workingDir": ".",
            "shell": true
        }
    ],
    "export": {
        "enabled": false
    }
}